<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Infrastructure Automation Dashboard — Dasun Sandeepa</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --base:     #0d1117;
    --surface:  #161b22;
    --surface2: #1c2128;
    --border:   #30363d;
    --accent:   #00d4ff;
    --green:    #3fb950;
    --muted:    #8b949e;
    --text:     #e6edf3;
    --subtext:  #c9d1d9;
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Inter', sans-serif;
  }

  body {
    background: var(--base);
    color: var(--text);
    font-family: var(--sans);
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 48px 24px;
  }

  .page { width: 100%; max-width: 960px; }

  /* ── TOP BAR ── */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 36px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    gap: 12px;
  }

  .topbar-left {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--muted);
  }

  .topbar-left .aws-badge {
    background: rgba(255, 153, 0, 0.12);
    border: 1px solid rgba(255, 153, 0, 0.3);
    color: #ff9900;
    padding: 3px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
  }

  .topbar-left .sep { color: var(--border); }
  .topbar-left .env { color: var(--subtext); }
  .topbar-left .branch { color: var(--accent); }

  .status-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(63, 185, 80, 0.1);
    border: 1px solid rgba(63, 185, 80, 0.3);
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 12px;
    font-weight: 600;
    color: var(--green);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .pulse-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-out infinite;
  }

  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 rgba(63,185,80,.6); }
    70%  { box-shadow: 0 0 0 7px rgba(63,185,80,0); }
    100% { box-shadow: 0 0 0 0 rgba(63,185,80,0); }
  }

  /* ── HERO ── */
  .hero { margin-bottom: 32px; }

  .hero-label {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero-label::after {
    content: '';
    display: block;
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(0,212,255,.3), transparent);
  }

  .hero h1 {
    font-size: clamp(24px, 4vw, 38px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .hero h1 .accent { color: var(--accent); }

  .hero-sub {
    font-size: 15px;
    color: var(--muted);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  /* ── HEALTH BADGE ── */
  .health-badge {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    background: rgba(63,185,80,0.07);
    border: 1px solid rgba(63,185,80,0.25);
    border-radius: 14px;
    padding: 18px 36px;
    margin-bottom: 36px;
  }

  .health-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .health-value {
    font-size: 22px;
    font-weight: 700;
    color: var(--green);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .health-dot {
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-out infinite;
  }

  /* ── DEPLOYMENT SUMMARY ── */
  .summary-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 22px 24px;
    margin-bottom: 32px;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 10px;
    margin-top: 16px;
  }

  .summary-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13.5px;
    color: var(--subtext);
    font-weight: 500;
  }

  .summary-item .check {
    width: 18px; height: 18px;
    border-radius: 50%;
    background: rgba(63,185,80,0.15);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    font-size: 10px;
    color: var(--green);
  }

  /* ── SECTION TITLES ── */
  .section-title {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-title::before {
    content: '';
    width: 3px; height: 14px;
    border-radius: 2px;
    background: var(--accent);
    display: block;
  }

  /* ── THREE SECTION GROUPS ── */
  .dashboard-sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 32px;
  }

  .section-group {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
  }

  /* ── METRIC CARDS inside groups ── */
  .metric-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 10px;
    transition: border-color 0.2s, background 0.2s;
    position: relative;
    overflow: hidden;
    background: var(--surface2);
  }

  .metric-card:last-child { margin-bottom: 0; }

  .metric-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .metric-card:hover { border-color: rgba(0,212,255,0.35); }
  .metric-card:hover::before { opacity: 1; }

  .metric-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 5px;
  }

  .metric-value {
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.4;
    word-break: break-all;
  }

  .metric-value.green { color: var(--green); }

  .service-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .service-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--green);
  }

  .service-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-out infinite;
  }

  /* ── FOOTER ── */
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .author { display: flex; flex-direction: column; gap: 4px; }

  .author-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 500;
  }

  .author-name {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .author-role { font-size: 13px; color: var(--muted); }
  .author-focus { font-size: 12px; color: var(--accent); font-family: var(--mono); margin-top: 2px; }

  .tech-stack { display: flex; flex-wrap: wrap; gap: 8px; }

  .tech-badge {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 6px;
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--muted);
    letter-spacing: 0.04em;
    transition: color 0.2s, border-color 0.2s;
  }

  .tech-badge:hover { color: var(--accent); border-color: rgba(0,212,255,0.3); }

  @media (max-width: 560px) {
    body { padding: 24px 16px; }
    .footer { flex-direction: column; align-items: flex-start; }
    .topbar-left { display: none; }
  }
</style>
</head>
<body>
<div class="page">

  <!-- TOP BAR -->
  <div class="topbar">
    <div class="topbar-left">
      <span class="aws-badge">AWS EC2</span>
      <span class="sep">|</span>
      <span class="env">Production Environment</span>
      <span class="sep">·</span>
      <span class="branch">main</span>
    </div>
    <div class="status-pill">
      <span class="pulse-dot"></span>
      Infrastructure Healthy
    </div>
  </div>

  <!-- HERO -->
  <div class="hero">
    <div class="hero-label">Ansible · Automated Deployment · AWS EC2 · Ubuntu 22.04 LTS</div>
    <h1>🚀 Automated Infrastructure Deployment<br><span class="accent">Provisioned Successfully</span></h1>
    <p class="hero-sub">Automated provisioning and configuration via Ansible playbooks. All services deployed, verified, and running.</p>
  </div>

  <!-- HEALTH BADGE -->
  <div class="health-badge">
    <div class="health-label">Infrastructure Status</div>
    <div class="health-value"><span class="health-dot"></span> HEALTHY</div>
  </div>

  <!-- DEPLOYMENT SUMMARY -->
  <div class="summary-panel">
    <div class="section-title">Deployment Summary</div>
    <div class="summary-grid">
      <div class="summary-item"><span class="check">✓</span>Ubuntu System Updated</div>
      <div class="summary-item"><span class="check">✓</span>Docker Installed</div>
      <div class="summary-item"><span class="check">✓</span>Nginx Installed &amp; Running</div>
      <div class="summary-item"><span class="check">✓</span>DevOps User Created</div>
      <div class="summary-item"><span class="check">✓</span>SSH Authentication Configured</div>
      <div class="summary-item"><span class="check">✓</span>Web Dashboard Deployed</div>
    </div>
  </div>

  <!-- THREE DASHBOARD SECTIONS -->
  <div class="dashboard-sections">

    <!-- INFRASTRUCTURE -->
    <div class="section-group">
      <div class="section-title">Infrastructure</div>

      <div class="metric-card">
        <div class="metric-label">Hostname</div>
        <div class="metric-value">{{ ansible_hostname }}</div>
      </div>

      <div class="metric-card">
        <div class="metric-label">Operating System</div>
        <div class="metric-value">{{ ansible_distribution }} {{ ansible_distribution_version }}</div>
      </div>

      <div class="metric-card">
        <div class="metric-label">Kernel Version</div>
        <div class="metric-value">{{ ansible_kernel }}</div>
      </div>

      <div class="metric-card">
        <div class="metric-label">Architecture</div>
        <div class="metric-value">{{ ansible_architecture }}</div>
      </div>

      <div class="metric-card">
        <div class="metric-label">Deployed At</div>
        <div class="metric-value">{{ ansible_date_time.date }} · {{ ansible_date_time.time }}</div>
      </div>
    </div>

    <!-- NETWORKING -->
    <div class="section-group">
      <div class="section-title">Networking</div>

      <div class="metric-card">
        <div class="metric-label">Private IP Address</div>
        <div class="metric-value">{{ ansible_default_ipv4.address }}</div>
      </div>

      <div class="metric-card">
        <div class="metric-label">Subnet IP Address</div>
        <div class="metric-value">{{ ansible_default_ipv4.network }}</div>
      </div>

      <div class="metric-card">
        <div class="metric-label">Network Interface</div>
        <div class="metric-value">{{ ansible_default_ipv4.interface }}</div>
      </div>

      <div class="metric-card">
        <div class="metric-label">SSH Authentication</div>
        <div class="metric-value green">✓ Enabled &amp; Configured</div>
      </div>

      <div class="metric-card">
        <div class="metric-label">Managed By</div>
        <div class="metric-value">Ansible Automation</div>
      </div>
    </div>

    <!-- SERVICES -->
    <div class="section-group">
      <div class="section-title">Services</div>

      <div class="metric-card">
        <div class="metric-label">Docker</div>
        <div class="service-row">
          <div class="metric-value">{{ ansible_docker_version | default('29.1.3') }}</div>
          <div class="service-status"><span class="service-dot"></span>Running</div>
        </div>
      </div>

      <div class="metric-card">
        <div class="metric-label">Nginx</div>
        <div class="service-row">
          <div class="metric-value">Web Server</div>
          <div class="service-status"><span class="service-dot"></span>Active</div>
        </div>
      </div>

      <div class="metric-card">
        <div class="metric-label">DevOps User</div>
        <div class="service-row">
          <div class="metric-value">devops</div>
          <div class="service-status"><span class="service-dot"></span>Created</div>
        </div>
      </div>

      <div class="metric-card">
        <div class="metric-label">Ansible</div>
        <div class="service-row">
          <div class="metric-value">Playbook</div>
          <div class="service-status"><span class="service-dot"></span>Complete</div>
        </div>
      </div>
    </div>

  </div>

  <!-- FOOTER -->
  <div class="footer">
    <div class="author">
      <span class="author-label">Provisioned &amp; Managed By</span>
      <span class="author-name">Dasun Sandeepa</span>
      <span class="author-role">BSc (Hons) Software Engineering Undergraduate</span>
      <span class="author-focus">DevOps · Cloud · Automation</span>
    </div>
    <div class="tech-stack">
      <span class="tech-badge">AWS</span>
      <span class="tech-badge">Linux</span>
      <span class="tech-badge">Bash</span>
      <span class="tech-badge">Python</span>
      <span class="tech-badge">Ansible</span>
      <span class="tech-badge">Docker</span>
      <span class="tech-badge">Nginx</span>
      <span class="tech-badge">DevOps</span>
    </div>
  </div>

</div>
</body>
</html>